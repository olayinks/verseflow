{
  "name": "verseflow",
  "version": "1.0.0",
  "description": "Real-time Bible verse and worship lyric detection for church services",
  "main": "./out/main/index.js",
  "author": "VerseFlow",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:py": "py -3.13 -m pytest -v",
    "pack": "npm run build && electron-builder --dir",
    "sidecar:build": "pyinstaller sidecar/verseflow_sidecar.spec --distpath dist --workpath build/pyinstaller",
    "dist:win": "npm run build && npm run sidecar:build && electron-builder --win",
    "dist:mac": "npm run build && npm run sidecar:build && electron-builder --mac",
    "sidecar:dev": "py -3.13 sidecar/main.py data/dev-config.json",
    "sidecar:mock": "py -3.13 sidecar/tests/mock_sidecar.py",
    "sidecar:install": "py -3.13 -m pip install -r sidecar/requirements.txt",
    "scripts:build-bible": "py -3.13 scripts/build_bible_index.py",
    "scripts:build-lyrics": "py -3.13 scripts/build_lyrics_index.py",
    "scripts:download-models": "py -3.13 scripts/download_models.py"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.56.0",
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.446.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.14.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.4",
    "vite": "^8.0.3",
    "vitest": "^3.2.4"
  }
}
